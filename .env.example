# ── Required ──────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.eventra.com
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
VITE_PAYMENT_GATEWAY_PUBLIC_KEY=your_payment_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_POSTHOG_KEY=your_posthog_key_here

# Development only — enables mock data mode when true or when VITE_API_URL is unset
VITE_ENABLE_MOCK_AI=true
